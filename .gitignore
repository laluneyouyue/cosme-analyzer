# =============================================================================
# .gitignore - Gitで管理しないファイル・ディレクトリを指定する設定ファイル
# =============================================================================
# このファイルに書いたパターンに一致するファイルはGitにコミットされません。
# APIキーなどの秘密情報や、自動生成されるファイルを除外するために重要です。

# =============================================================================
# 秘密情報・環境設定ファイル（絶対にコミットしてはいけない！）
# =============================================================================
.env
.env.local
.env.production
backend/.env
frontend/.env

# =============================================================================
# Node.js / フロントエンド
# =============================================================================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# =============================================================================
# Python / バックエンド
# =============================================================================
__pycache__/
backend/__pycache__/
*.py[cod]
*.pyo
*.pyd

# Python仮想環境（venvやpoetryで作成される）
.venv/
backend/.venv/
venv/
ENV/

# =============================================================================
# IDE・エディタの設定ファイル
# =============================================================================
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store          # macOSが自動生成するファイル
Thumbs.db          # Windowsが自動生成するファイル

# =============================================================================
# ログファイル
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*

# LLMデバッグログ（プロンプトとレスポンスを保存するファイル）
# 個人の解析データが含まれるためリポジトリには含めない
backend/logs/
